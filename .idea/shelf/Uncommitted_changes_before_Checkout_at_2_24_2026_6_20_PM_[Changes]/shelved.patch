<+>@startuml\r\ntitle Power System Data Model (Milestone 1)\r\n\r\nclass Bus {\r\n  +bus_counter : int {static}\r\n  +name : str\r\n  +nominal_kv : float\r\n  +bus_index : int\r\n}\r\n\r\nclass Transformer {\r\n  +name : str\r\n  +bus1_name : str\r\n  +bus2_name : str\r\n  +r : float\r\n  +x : float\r\n}\r\n\r\nclass TransmissionLine {\r\n  +name : str\r\n  +bus1_name : str\r\n  +bus2_name : str\r\n  +r : float\r\n  +x : float\r\n  +g : float\r\n  +b : float\r\n}\r\n\r\nclass Load {\r\n  +name : str\r\n  +bus1_name : str\r\n  +mw : float\r\n  +mvar : float\r\n}\r\n\r\nclass Generator {\r\n  +name : str\r\n  +bus1_name : str\r\n  +voltage_setpoint : float\r\n  +mw_setpoint : float\r\n}\r\n\r\nclass Circuit {\r\n  +name: str\r\n  +buses: Dict[str, Bus]\r\n  +loads: Dict[str, Load]\r\n  +generators: Dict[str, Load]\r\n  +transmission_lines: Dict[str, TransmissionLine]\r\n  +transformers: Dict[str, Transformer]\r\n  +add_bus(self, name: str, nominal_kv: float)\r\n  +add_transformer(self, name: str, bus1_name: str, bus2_name: str, r: float, x: float)\r\n  +add_transmission_line(self, name:str, bus1_name:str, bus2_name:str, r:float, x:float, g:float, b:float):\r\n  +add_generator(self, name: str, bus1_name, voltage_setpoint:float, mw_setpoint: float)\r\n  +add_load(self, name: str, bus1_name: str, mw:float, mvar:float)\r\n  }\r\n\r\n\r\n\r\n' Relationships (your classes store bus names as strings, so these are dependencies)\r\nTransformer ..> Circuit : contains\r\nTransmissionLine ..> Circuit : contains\r\nLoad ..> Circuit : contains\r\nGenerator ..> Circuit : contains\r\nBus ..> Circuit : contains\r\n@enduml\r\n
